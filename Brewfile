# ==========================================
# Auto-WorkStation Brewfile
# 完整开发工作站恢复清单
# 安装: brew bundle --file=Brewfile
# ==========================================

# --- 版本控制 ---
brew "git"

# --- Shell（覆盖 macOS 自带旧版） ---
brew "bash"
brew "zsh"

# --- 版本管理器 ---
brew "pyenv"            # Python 版本隔离

# --- dotfiles 管理 ---
brew "chezmoi"

# --- 文档处理 ---
brew "antiword"         # 解析 .doc 文件
brew "pandoc"           # 通用文档格式转换
brew "poppler"          # PDF 渲染引擎
brew "djvulibre"        # DjVu 文档格式支持

# --- 多媒体 ---
brew "ffmpeg"           # 音视频处理

# --- OCR ---
brew "tesseract-lang"   # Tesseract OCR + 语言包

# --- GUI 应用 ---
cask "visual-studio-code"
cask "libreoffice"
